{
  "name": "kingnation-launcher",
  "version": "1.6.6",
  "description": "Launcher Officiel de KingNation",
  "main": "main.js",
  "author": "KingNation",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "node scripts/build.js",
    "build:win": "node scripts/build.js --win",
    "release:win": "node scripts/build.js --win --publish always",
    "pack": "node scripts/build.js --dir",
    "test": "node --test test/discord.test.js test/updater.test.js test/download.test.js"
  },
  "build": {
    "electronVersion": "32.2.0",
    "appId": "com.kingnation.launcher",
    "productName": "KingNation Launcher",
    "artifactName": "kingnation_installer.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "theworldorder67",
        "repo": "kingnation-launcher",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/logo.png",
      "executableName": "KingNation Launcher"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KingNation Launcher"
    }
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "axios": "^1.7.7",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "javascript-obfuscator": "^5.4.3"
  }
}
